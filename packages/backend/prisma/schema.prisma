generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Url {
  id          String   @id @default(cuid())
  originalUrl String
  slug        String   @unique
  createdAt   DateTime @default(now())
  clicks      Click[]
}

model Click {
  id        String   @id @default(cuid())
  url       Url      @relation(fields: [urlId], references: [id], onDelete: Cascade)
  urlId     String
  createdAt DateTime @default(now())
}
